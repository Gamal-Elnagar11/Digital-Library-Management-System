@model IEnumerable<Order>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "AllOrders";
}

<div style="width:100%" class="mt-2">

<h3>AllOrders</h3>
    @if (Model != null && Model.Count() > 0)
    {
        <table class="table table-striped">
            <tr>
                <th>OrderDate</th>
                <th>Name</th>
                <th>MobileNo</th>
                <th>Email</th>
                <th>Address</th>
                <th>PaymentStatus</th>
                <th>OrderStatus</th>
                <th>Action</th>
            </tr>

            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.CreatedDate.ToString("dd-MM-yyyy")</td>
                    <td>@order.Name</td>
                    <td>@order.MobileNumber</td>
                    <td>@order.Email</td>
                    <td>@order.Address</td>
                    <td>@order.PaymentMethod| @(order.IsPaid ? "Paid" : "Not Paid")</td>
                    <td>@order.orderStatus.StatusName</td>
                    <td>
                        <button type="button" data-bs-toggle="modal" data-bs-target="#modal-@order.Id" class="btn btn-primary">
                            Order-Detail
                        </button>
                        <a asp-action="UpdateOrderStatus" asp-route-orderId="@order.Id" class="btn btn-info">  Change Order Status  </a>
                        <br />
                        <a asp-action="TogglePaymentStatus" asp-route-orderId="@order.Id" class="btn btn-info">Toggle Payment Status</a>
                        @await Html.PartialAsync("/Views/AdminOperations/_OrderDetailModel.cshtml"
                                                 , new OrderDetailModelDTO {DivId = order.Id.ToString(),
                                                 OrderDetail = order.orderDetail})
                    </td>




                </tr>
            }

        </table>
    }







</div>








